NODE_ENV=development

# Puerto del servidor Express (ej. 3007 si coincide con el front local)
PORT=3007

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=

# En producción (NODE_ENV=production): obligatorio y no uses el valor por defecto "secret"
JWT_SECRET=

# En producción deben estar definidos: DB_HOST, DB_PORT, DB_USER, DB_PASSWORD, DB_NAME y JWT_SECRET (seguro).
